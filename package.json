{
  "name": "@agledger/mcp-server",
  "version": "2.0.0",
  "description": "AGLedger MCP Server — Thin API pass-through for AI agents via MCP protocol",
  "license": "SEE LICENSE IN LICENSE",
  "author": "AGLedger LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/agledger-ai/mcp-server"
  },
  "homepage": "https://agledger.ai",
  "keywords": [
    "agledger",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "accountability",
    "audit"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agledger-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
